        // Active State of Student Recap Data
        let currentValues = {
            matsurat: 0,
            dhuha: 0,
            rawatib: 0,
            jamaah: 0,
            puasa: 0,
            tahajjud: 0
        };

        const batteryStates = {
            low: {
                title: "Jiwa Remaja Low-Bat (Kritis!)",
                desc: "Sering malas gerak, overthinking, hampa, tidak tenang, gampang terbawa emosi negatif. Yuk terus colok charger rohanimu!",
                buff: "<i class='fa-solid fa-bolt-lightning animate-pulse'></i> Butuh Charger: Tingkatkan dhuha, rawatib & dzikir sekarang!",
                class: "from-gameRed to-orange-500",
                textClass: "text-gameRed"
            },
            medium: {
                title: "Energi Seimbang (Stabil)",
                desc: "Fokus belajar stabil, hati relatif tenang, ibadah harian mulai terbentuk secara berkala. Masih perlu dorongan agar mencapai daya penuh!",
                buff: "<i class='fa-solid fa-battery-half'></i> Spiritual Buff: Tingkatkan shalat berjamaah & tahajjud pembuka pintu langit!",
                class: "from-amber-500 to-yellow-400",
                textClass: "text-amber-500"
            },
            high: {
                title: "Rabbani Master (Full Charged!)",
                desc: "Jiwa sangat lapang, fokus belajar tajam, hati diliputi optimisme & kedamaian, akhlak tangguh membentengi dari pengaruh buruk.",
                buff: "<i class='fa-solid fa-circle-check animate-bounce'></i> VIP Buff: Dijamin ketenangan lahir batin & pertolongan Allah dari segala arah!",
                class: "from-emerald-500 to-gameGreen",
                textClass: "text-gameGreen"
            }
        };

        const avatars = [
            "fa-user-ninja",
            "fa-user-shield",
            "fa-user-astronaut",
            "fa-user-tie",
            "fa-user-graduate",
            "fa-crown"
        ];
        let currentAvatarIndex = 0;
        let playerCustomRole = "Pejuang Subuh";
        let currentBatteryPercentage = 10;

        window.addEventListener('load', function() {
            // Restore any locally cached commitment
            const savedCommitment = localStorage.getItem('spirit_card_commitment');
            if (savedCommitment) {
                document.getElementById('card-commitment-text').value = savedCommitment;
            } else {
                document.getElementById('card-commitment-text').value = "Saya meluangkan waktu beribadah bukan karena disuruh orang tua atau guru, melainkan karena jiwa saya butuh perlindungan dan tuntunan Allah setiap waktu.";
            }

            // Set default date input value to today
            const todayInput = new Date().toISOString().split('T')[0];
            document.getElementById('recap-date-input').value = todayInput;

            // Populate all number groups dynamically
            generateSelectionButtons();
            
            // Set up initial state of card and battery status
            updateTimestamp();
            calculateBattery();
        });

        // Dynamic generation of selection buttons for precise choice values
        function generateSelectionButtons() {
            Object.keys(maxTargets).forEach(key => {
                const container = document.getElementById(`btn-group-${key}`);
                const max = maxTargets[key];
                container.innerHTML = "";

                for(let i = 0; i <= max; i++) {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.innerText = `${i}x`;
                    btn.id = `btn-${key}-${i}`;
                    
                    // Style base button classes
                    btn.className = "px-3 py-1.5 rounded-lg font-extrabold text-[11px] md:text-xs transition-all border border-slate-200/80 bg-white text-slate-700 hover:border-questPrimary hover:bg-slate-50";
                    btn.setAttribute('onclick', `selectCountValue('${key}', ${i})`);
                    
                    container.appendChild(btn);
                }
                
                // Select 0 value initially
                selectCountValue(key, 0);
            });
        }

        // Action when a student clicks on an exact count value button
        window.selectCountValue = function(key, val) {
            currentValues[key] = val;
            
            // Reset background styles of all sibling buttons in this group
            const max = maxTargets[key];
            for (let i = 0; i <= max; i++) {
                const btn = document.getElementById(`btn-${key}-${i}`);
                if (btn) {
                    btn.className = "px-3 py-1.5 rounded-lg font-extrabold text-[11px] md:text-xs transition-all border border-slate-200/80 bg-white text-slate-700 hover:border-questPrimary hover:bg-slate-50";
                }
            }

            // High-contrast highlighted style for active button
            const activeBtn = document.getElementById(`btn-${key}-${val}`);
            if (activeBtn) {
                activeBtn.className = "px-3 py-1.5 rounded-lg font-extrabold text-[11px] md:text-xs transition-all border border-questPrimary bg-questPrimary text-white shadow-sm scale-105";
            }

            // Update individual count labels inside the recap block on the card
            document.getElementById(`recap-${key}`).innerText = `${val}/${max}`;

            // Recalculate battery & progress
            calculateBattery();
        };

        // Reset all tactile count values back to 0
        window.resetCounters = function() {
            Object.keys(maxTargets).forEach(key => {
                selectCountValue(key, 0);
            });
        };

        // Calculate interactive battery metrics based on actual progress ratios
        function calculateBattery() {
            let totalMaxWeight = 0;
            let currentAccumulated = 0;

            const weights = {
                matsurat: 15,
                dhuha: 15,
                rawatib: 15,
                jamaah: 20,
                puasa: 15,
                tahajjud: 20
            };

            Object.keys(maxTargets).forEach(key => {
                const weight = weights[key];
                const ratio = currentValues[key] / maxTargets[key];
                currentAccumulated += ratio * weight;
                totalMaxWeight += weight;
            });

            // Base charge is 10%, scaled remaining 90% is based on spiritual activities completed
            let pct = Math.round(10 + (currentAccumulated / totalMaxWeight) * 90);
            if (pct > 100) pct = 100;
            currentBatteryPercentage = pct;

            // Render visual changes
            const bar = document.getElementById('sim-battery-bar');
            const pctText = document.getElementById('sim-pct');
            const spiritLevelText = document.getElementById('spirit-level-text');
            const spiritProgressBar = document.getElementById('spirit-progress-bar');

            bar.style.width = pct + '%';
            pctText.innerText = pct + '%';
            spiritProgressBar.style.width = pct + '%';

            // Determine current status criteria mapping
            let currentStatus = batteryStates.low;
            if (pct <= 30) {
                spiritLevelText.innerText = "NOVICE WARRIOR (" + pct + "%)";
            } else if (pct < 80) {
                spiritLevelText.innerText = "SOUL GUARDIAN (" + pct + "%)";
                currentStatus = batteryStates.medium;
            } else {
                spiritLevelText.innerText = "RABBANI MASTER (" + pct + "%)";
                currentStatus = batteryStates.high;
            }

            // Sync visual battery status card
            bar.className = "h-full bg-gradient-to-r rounded-xl transition-all duration-500 flex items-center justify-center font-bold text-white text-xs md:text-sm drop-shadow " + currentStatus.class;
            
            const statusTitle = document.getElementById('sim-status-title');
            statusTitle.innerText = currentStatus.title;
            statusTitle.className = "font-bold text-sm md:text-base font-game " + currentStatus.textClass;
            
            document.getElementById('sim-status-desc').innerText = currentStatus.desc;
            
            const statusBuff = document.getElementById('sim-status-buff');
            statusBuff.innerHTML = currentStatus.buff;

            // Apply relative helper visual stylings based on battery category
            if (pct <= 30) {
                statusBuff.className = "mt-3 p-2 rounded-lg bg-red-50 border border-red-100/50 text-[11px] text-gameRed font-semibold flex items-center gap-1.5";
            } else if (pct < 80) {
                statusBuff.className = "mt-3 p-2 rounded-lg bg-amber-50 border border-amber-100/50 text-[11px] text-amber-800 font-semibold flex items-center gap-1.5";
            } else {
                statusBuff.className = "mt-3 p-2 rounded-lg bg-emerald-50 border border-emerald-100/50 text-[11px] text-emerald-800 font-semibold flex items-center gap-1.5";
            }
        }

        // Cycle profile avatars inside card
        window.cycleAvatar = function() {
            currentAvatarIndex = (currentAvatarIndex + 1) % avatars.length;
            updateAvatarVisual();
        };

        function updateAvatarVisual() {
            const avatarEl = document.getElementById('card-avatar');
            avatarEl.className = `fa-solid ${avatars[currentAvatarIndex]}`;
        }

        // Change Custom spiritual character classes
        window.changeCustomRole = function() {
            const list = ["Pejuang Subuh", "Penghafal Al-Qur'an", "Duta Kebaikan", "Mujahid Halaqah", "Ksatria Masjid"];
            const currentIdx = list.indexOf(playerCustomRole);
            const nextIdx = (currentIdx + 1) % list.length;
            playerCustomRole = list[nextIdx];
            document.getElementById('card-custom-role').innerText = `Role: ${playerCustomRole} (Ganti)`;
        };

        // Cache text area text locally inside client-browser to survive session refreshes
        window.saveLocalCommitment = function() {
            const val = document.getElementById('card-commitment-text').value;
            localStorage.setItem('spirit_card_commitment', val);
        };

        // Synchronize and render active player name
        window.updatePlayerName = function() {
            const inputVal = document.getElementById('player-name-input').value;
            const name = inputVal.trim() !== "" ? inputVal : "Guest Warrior";
            document.getElementById('card-player-name').innerText = name;
        };

        // Synchronize Class on preview card
        window.updatePlayerClass = function() {
            const selectVal = document.getElementById('player-class-select').value;
            const displayVal = selectVal ? `Class: ${selectVal}` : 'Class: -';
            document.getElementById('card-player-class').innerText = displayVal;
        };

        // Trigger timestamp recalculations
        window.updateRecapWeek = function() {
            updateTimestamp();
        };

        window.updateRecapDate = function() {
            updateTimestamp();
        };

        function updateTimestamp() {
            const weekVal = document.getElementById('recap-week-select').value;
            const dateVal = document.getElementById('recap-date-input').value;
            
            let dateFormatted = "Today";
            if (dateVal) {
                const d = new Date(dateVal);
                if (!isNaN(d.getTime())) {
                    dateFormatted = d.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
                }
            }
            
            document.getElementById('card-timestamp').innerText = `${weekVal} (${dateFormatted})`;
        }

        // Modal & Overlay Dialog View Switch controllers
        window.toggleTeacherPortal = function() {
            document.getElementById('teacher-portal-modal').classList.remove('hidden');
            document.getElementById('teacher-portal-container').classList.add('scale-100');
            document.getElementById('teacher-portal-container').classList.remove('scale-95');
        };

        window.closeTeacherPortal = function() {
            document.getElementById('teacher-portal-modal').classList.add('hidden');
            document.getElementById('teacher-portal-container').classList.add('scale-95');
            document.getElementById('teacher-portal-container').classList.remove('scale-100');
        };

        window.authenticateTeacher = function() {
            const pin = document.getElementById('teacher-pin-input').value;
            if (pin === "PAI2026" || pin === "GURUBI2026" || pin === "BINAINSANI" || pin === "USTAZ2026") {
                document.getElementById('teacher-auth-gate').classList.add('hidden');
                document.getElementById('teacher-dashboard-view').classList.remove('hidden');
                document.getElementById('auth-error-msg').classList.add('hidden');
                
                // Fetch student records from DB
                loadDatabaseFromCloud();
            } else {
                document.getElementById('auth-error-msg').classList.remove('hidden');
            }
        };

        window.openFeedbackModal = function(id, name, existingFeedback) {
            document.getElementById('feedback-student-id').value = id;
            document.getElementById('feedback-student-name').value = name;
            document.getElementById('feedback-text-area').value = existingFeedback || "";
            document.getElementById('teacher-feedback-modal').classList.remove('hidden');
        };

        window.closeFeedbackModal = function() {
            document.getElementById('teacher-feedback-modal').classList.add('hidden');
        };
    </script>
</body>
</html>
