    <!-- FIREBASE MODULES -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, onSnapshot, collection, getDocs, deleteDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Firebase Configuration Fallback Block
        let app, db, auth;
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'rabbani-spirit-quest-default';
        const rawConfig = typeof __firebase_config !== 'undefined' ? __firebase_config : null;
        
        let firebaseConfig = {};
        if (rawConfig) {
            try {
                firebaseConfig = JSON.parse(rawConfig);
            } catch (e) {
                console.warn("Could not parse provided firebase configuration. Mock state active.");
            }
        }

        // Initialize Firebase if config is valid
        if (firebaseConfig.apiKey) {
            app = initializeApp(firebaseConfig);
            db = getFirestore(app);
            auth = getAuth(app);
            
            // Auto authenticate immediately on start
            authenticateUser();
        } else {
            console.warn("No valid Firebase credentials. Using offline demo database.");
        }

        // Authenticate student anonymously
        async function authenticateUser() {
            if (!auth) return;
            try {
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth);
                }
                console.log("Firebase authenticated successfully as:", auth.currentUser.uid);
                
                // Set up real-time listener for current student to pull ustadz feedback instantly
                listenToCurrentStudentRecord();
            } catch (error) {
                console.error("Firebase auth error:", error);
            }
        }

        // Save current progress to Firestore Database
        window.saveStudentProgress = async function() {
            // Prepare record data
            const record = {
                uid: auth ? auth.currentUser.uid : 'offline-demo-id',
                name: document.getElementById('player-name-input').value.trim() || 'Guest Warrior',
                class: document.getElementById('player-class-select').value || '-',
                week: document.getElementById('recap-week-select').value || 'Pekan 1',
                date: document.getElementById('recap-date-input').value || new Date().toISOString().split('T')[0],
                matsurat: currentValues.matsurat,
                dhuha: currentValues.dhuha,
                rawatib: currentValues.rawatib,
                jamaah: currentValues.jamaah,
                puasa: currentValues.puasa,
                tahajjud: currentValues.tahajjud,
                battery: currentBatteryPercentage,
                role: playerCustomRole,
                avatarIndex: currentAvatarIndex,
                commitment: document.getElementById('card-commitment-text').value,
                timestamp: document.getElementById('card-timestamp').innerText,
                updatedAt: new Date().toISOString()
            };

            const statusBox = document.getElementById('sync-status');
            statusBox.className = "text-xs py-2 px-3 rounded-lg text-center font-semibold bg-blue-50 text-blue-700 block";
            statusBox.innerHTML = "<i class='fa-solid fa-spinner animate-spin'></i> Menyimpan ke cloud...";

            if (!db || !auth) {
                // Offline fallback
                localStorage.setItem('offline_progress', JSON.stringify(record));
                setTimeout(() => {
                    statusBox.className = "text-xs py-2 px-3 rounded-lg text-center font-semibold bg-amber-50 text-amber-700 block";
                    statusBox.innerHTML = "<i class='fa-solid fa-triangle-exclamation'></i> Tersimpan Lokal (Offline Mode)";
                }, 800);
                return;
            }

            try {
                // RULE 1: STRICT PATH
                const recordRef = doc(db, 'artifacts', appId, 'public', 'data', 'student_recap', auth.currentUser.uid);
                
                // Merge with any existing fields (such as previous feedback sent by teacher)
                const existingSnap = await getDoc(recordRef);
                if (existingSnap.exists()) {
                    const existingData = existingSnap.data();
                    record.feedback = existingData.feedback || "";
                } else {
                    record.feedback = "";
                }

                await setDoc(recordRef, record);
                
                statusBox.className = "text-xs py-2 px-3 rounded-lg text-center font-semibold bg-emerald-50 text-emerald-700 block";
                statusBox.innerHTML = "<i class='fa-solid fa-cloud-arrow-up'></i> Capaian Berhasil Dikirim ke Cloud!";
                setTimeout(() => statusBox.classList.add('hidden'), 5000);
            } catch (error) {
                console.error("Error saving to Firestore:", error);
                statusBox.className = "text-xs py-2 px-3 rounded-lg text-center font-semibold bg-red-50 text-red-700 block";
                statusBox.innerHTML = "<i class='fa-solid fa-circle-exclamation'></i> Gagal menyimpan: " + error.message;
            }
        };

        // Real-time listener for current student record (to pull feedback on the fly)
        function listenToCurrentStudentRecord() {
            if (!db || !auth) return;
            
            // RULE 1: STRICT PATH
            const recordRef = doc(db, 'artifacts', appId, 'public', 'data', 'student_recap', auth.currentUser.uid);
            
            onSnapshot(recordRef, (docSnap) => {
                if (docSnap.exists()) {
                    const data = docSnap.data();
                    if (data.feedback && data.feedback.trim() !== "") {
                        document.getElementById('ustadz-feedback-wrapper').classList.remove('hidden');
                        document.getElementById('ustadz-feedback-text').innerText = `"${data.feedback}"`;
                    } else {
                        document.getElementById('ustadz-feedback-wrapper').classList.add('hidden');
                    }
                    
                    // Auto-restore offline name/role if it was not edited during this session
                    if (document.getElementById('player-name-input').value.trim() === "" || document.getElementById('player-name-input').value === "Guest Warrior") {
                        if (data.name) {
                            document.getElementById('player-name-input').value = data.name;
                            updatePlayerName();
                        }
                    }
                    if (data.class) {
                        document.getElementById('player-class-select').value = data.class;
                        updatePlayerClass();
                    }
                    if (data.week) {
                        document.getElementById('recap-week-select').value = data.week;
                        updateRecapWeek();
                    }
                    if (data.date) {
                        document.getElementById('recap-date-input').value = data.date;
                        updateRecapDate();
                    }
                    if (data.commitment) {
                        document.getElementById('card-commitment-text').value = data.commitment;
                    }
                    if (data.avatarIndex !== undefined) {
                        currentAvatarIndex = data.avatarIndex;
                        updateAvatarVisual();
                    }
                    if (data.role) {
                        playerCustomRole = data.role;
                        document.getElementById('card-custom-role').innerText = `Role: ${playerCustomRole} (Ganti)`;
                    }
                }
            }, (error) => {
                console.warn("Realtime listener failed:", error);
            });
        }

        // Teacher Dashboard: Load all student records
        let allStudentRecords = [];
        window.loadDatabaseFromCloud = async function() {
            if (!db) {
                // Load dummy records for offline demonstration
                allStudentRecords = [
                    { id: '1', name: 'Zaid Al-Anshari', class: 'VII - A', week: 'Pekan 1', date: '2026-07-19', matsurat: 6, dhuha: 5, rawatib: 15, jamaah: 28, puasa: 1, tahajjud: 1, battery: 78, role: 'Pejuang Subuh', commitment: 'Ingin istiqamah demi berbakti pada ayah ibu', timestamp: 'Pekan 1 (19 Juli 2026)', feedback: 'Bagus nak, tingkatkan lagi rawatibnya!' },
                    { id: '2', name: 'Aisyah Humaira', class: 'VIII - B', week: 'Pekan 1', date: '2026-07-19', matsurat: 7, dhuha: 7, rawatib: 21, jamaah: 35, puasa: 1, tahajjud: 2, battery: 100, role: 'Penghafal Al-Qur\'an', commitment: 'Ibadah dhuha penyejuk jiwa pembuka hafalan.', timestamp: 'Pekan 1 (19 Juli 2026)', feedback: '' }
                ];
                renderTeacherTable();
                return;
            }

            try {
                // RULE 1 & 2: Get all records with a simple collection call
                const colRef = collection(db, 'artifacts', appId, 'public', 'data', 'student_recap');
                const querySnap = await getDocs(colRef);
                
                allStudentRecords = [];
                querySnap.forEach((doc) => {
                    allStudentRecords.push({ id: doc.id, ...doc.data() });
                });

                renderTeacherTable();
            } catch (error) {
                console.error("Error reading student records:", error);
            }
        };

        // Render Student records in Teacher Dashboard Table
        window.renderTeacherTable = function() {
            const tbody = document.getElementById('student-records-tbody');
            tbody.innerHTML = "";
            const searchVal = document.getElementById('teacher-search-input').value.toLowerCase().trim();

            const filtered = allStudentRecords.filter(r => 
                r.name.toLowerCase().includes(searchVal) || 
                (r.class && r.class.toLowerCase().includes(searchVal))
            );

            if (filtered.length === 0) {
                document.getElementById('no-records-msg').classList.remove('hidden');
                return;
            } else {
                document.getElementById('no-records-msg').classList.add('hidden');
            }

            filtered.forEach(record => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-slate-50 transition-colors";
                
                // Color badges for battery statuses
                let batteryBadge = "";
                if (record.battery <= 30) {
                    batteryBadge = `<span class="bg-red-100 text-gameRed px-2.5 py-1 rounded-full font-extrabold">${record.battery}%</span>`;
                } else if (record.battery < 80) {
                    batteryBadge = `<span class="bg-amber-100 text-amber-800 px-2.5 py-1 rounded-full font-extrabold">${record.battery}%</span>`;
                } else {
                    batteryBadge = `<span class="bg-emerald-100 text-emerald-800 px-2.5 py-1 rounded-full font-extrabold">${record.battery}%</span>`;
                }

                tr.innerHTML = `
                    <td class="p-4">
                        <div class="font-extrabold text-slate-800 text-xs md:text-sm">${record.name}</div>
                        <div class="text-[10px] text-slate-400 font-semibold uppercase">Kelas: ${record.class || '-'} • ${record.week || 'Pekan -'} • Log: ${record.timestamp || 'Today'}</div>
                        <div class="text-[10px] text-teal-600 font-semibold uppercase">Role: ${record.role || 'Pejuang'}</div>
                    </td>
                    <td class="p-4 text-center font-bold">
                        ${batteryBadge}
                    </td>
                    <td class="p-4">
                        <div class="grid grid-cols-2 gap-x-3 gap-y-0.5 text-[10px] text-slate-600 bg-slate-50 p-2 rounded-xl">
                            <div>Dzikir: <strong class="text-slate-800">${record.matsurat}/7</strong></div>
                            <div>Dhuha: <strong class="text-slate-800">${record.dhuha}/7</strong></div>
                            <div>Rawatib: <strong class="text-slate-800">${record.rawatib}/21</strong></div>
                            <div>Jamaah: <strong class="text-slate-800">${record.jamaah}/35</strong></div>
                            <div>Puasa: <strong class="text-slate-800">${record.puasa}/1</strong></div>
                            <div>Tahajjud: <strong class="text-slate-800">${record.tahajjud}/2</strong></div>
                        </div>
                    </td>
                    <td class="p-4 max-w-xs truncate text-[11px] italic text-slate-500" title="${record.commitment || ''}">
                        "${record.commitment || '-'}"
                    </td>
                    <td class="p-4">
                        <div class="flex items-center justify-center gap-2">
                            <button onclick="openFeedbackModal('${record.id}', '${record.name}', '${record.feedback || ''}')" class="bg-questSecondary hover:bg-yellow-500 text-questDark px-3 py-1.5 rounded-lg text-xs font-bold transition-all flex items-center gap-1 shadow-sm">
                                <i class="fa-solid fa-comment-dots"></i> Feedback
                            </button>
                            <button onclick="deleteStudentRecord('${record.id}')" class="bg-red-50 hover:bg-red-100 text-gameRed p-1.5 rounded-lg text-xs font-bold transition-all" title="Hapus Data">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                        ${record.feedback ? `<div class="text-[9px] text-emerald-700 italic mt-1 font-semibold truncate max-w-[150px]">Komentar: "${record.feedback}"</div>` : ''}
                    </td>
                `;
                tbody.appendChild(tr);
            });
        };

        // Submit Teacher Feedback directly to specific Student record
        window.submitTeacherFeedback = async function() {
            const studentId = document.getElementById('feedback-student-id').value;
            const text = document.getElementById('feedback-text-area').value.trim();

            if (!db) {
                // Offline fallback logic
                const idx = allStudentRecords.findIndex(r => r.id === studentId);
                if (idx !== -1) {
                    allStudentRecords[idx].feedback = text;
                    renderTeacherTable();
                }
                closeFeedbackModal();
                return;
            }

            try {
                // RULE 1: STRICT PATH
                const recordRef = doc(db, 'artifacts', appId, 'public', 'data', 'student_recap', studentId);
                await setDoc(recordRef, { feedback: text }, { merge: true });
                
                // Reload dashboard state
                await loadDatabaseFromCloud();
                closeFeedbackModal();
            } catch (error) {
                console.error("Error submitting feedback:", error);
            }
        };

        // Delete specific student record
        window.deleteStudentRecord = async function(studentId) {
            if (!confirm("Apakah Ustaz/Ustazah yakin ingin menghapus rekap data siswa ini dari database?")) return;

            if (!db) {
                allStudentRecords = allStudentRecords.filter(r => r.id !== studentId);
                renderTeacherTable();
                return;
            }

            try {
                // RULE 1: STRICT PATH
                const recordRef = doc(db, 'artifacts', appId, 'public', 'data', 'student_recap', studentId);
                await deleteDoc(recordRef);
                await loadDatabaseFromCloud();
            } catch (error) {
                console.error("Error deleting record:", error);
            }
        };

        // Export active table dataset to standard Excel-readable CSV format
        window.exportTableToCSV = function() {
            let csvContent = "data:text/csv;charset=utf-8,";
            csvContent += "Nama Siswa,Kelas,Pekan,Tanggal Log,Baterai Jiwa,Dzikir Matsurat,Shalat Dhuha,Rawatib,Jamaah Masjid,Puasa Kamis,Tahajjud,Komitmen Pribadi,Feedback Ustaz/Ustazah\n";

            allStudentRecords.forEach(r => {
                const row = [
                    `"${r.name}"`,
                    `"${r.class || '-'}"`,
                    `"${r.week || '-'}"`,
                    `"${r.timestamp || 'Today'}"`,
                    `"${r.battery}%"`,
                    `"${r.matsurat}/7"`,
                    `"${r.dhuha}/7"`,
                    `"${r.rawatib}/21"`,
                    `"${r.jamaah}/35"`,
                    `"${r.puasa}/1"`,
                    `"${r.tahajjud}/2"`,
                    `"${(r.commitment || '').replace(/"/g, '""')}"`,
                    `"${(r.feedback || '').replace(/"/g, '""')}"`
                ].join(",");
                csvContent += row + "\n";
            });

            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", `Rekap_Rabbani_Spirit_Quest_${new Date().toLocaleDateString('id-ID').replace(/\//g, '-')}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
    </script>

    <!-- INTERACTIVE PAGE RENDERING & DOM LOGIC -->
    <script>
        // Application Target Configurations
        const maxTargets = {
            matsurat: 7,
            dhuha: 7,
