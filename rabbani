<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rabbani Spirit Quest - SMP IT Bina Insani Kediri</title>
    <!-- Tailwind CSS for responsive framework utility -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Plus Jakarta Sans & Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        questPrimary: '#0F4C5C',
                        questSecondary: '#E3A857',
                        questDark: '#0B3945',
                        questLight: '#1B6B7F',
                        questBg: '#F4F7F6',
                        gameGreen: '#10B981',
                        gameRed: '#EF4444'
                    },
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                        game: ['"Poppins"', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        .quest-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .quest-card:hover {
            transform: translateY(-2px);
        }
        .glowing-btn {
            box-shadow: 0 0 15px rgba(227, 168, 87, 0.4);
        }
        .glowing-btn:hover {
            box-shadow: 0 0 25px rgba(227, 168, 87, 0.7);
        }
        .pulse-slow {
            animation: pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .7; }
        }
    </style>
</head>
<body class="bg-questBg font-sans text-slate-800 min-h-screen pb-12 selection:bg-questSecondary selection:text-questDark">

    <!-- TOP NAVBAR & PORTAL TOGGLER -->
    <nav class="bg-questDark text-white py-4 px-6 md:px-12 sticky top-0 z-40 border-b border-white/10 shadow-md">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-3">
                <span class="w-10 h-10 rounded-xl bg-questSecondary flex items-center justify-center text-questDark font-extrabold text-xl shadow-lg">
                    <i class="fa-solid fa-mosque"></i>
                </span>
                <div>
                    <h1 class="text-sm md:text-base font-bold font-game tracking-tight leading-tight">SMP IT Bina Insani</h1>
                    <p class="text-[10px] text-teal-200 tracking-wider">KEDIRI • GENERASI RABBANI</p>
                </div>
            </div>
            
            <div class="flex items-center gap-2">
                <!-- Teacher Portal Button -->
                <button onclick="toggleTeacherPortal()" class="bg-questSecondary hover:bg-yellow-500 text-questDark px-4 py-2 rounded-xl text-xs font-extrabold tracking-wider transition-all flex items-center gap-2 shadow-md">
                    <i class="fa-solid fa-chalkboard-user"></i> <span>PORTAL USTAZ / USTAZAH</span>
                </button>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <header class="bg-gradient-to-r from-questPrimary to-questLight text-white relative overflow-hidden py-12 px-4 md:px-8 border-b-4 border-questSecondary shadow-xl">
        <div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:24px_24px]"></div>
        
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8 relative z-10">
            <div class="text-center md:text-left">
                <div class="inline-flex items-center gap-2 bg-questSecondary/20 border border-questSecondary/40 text-questSecondary px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-3">
                    <i class="fa-solid fa-circle-nodes animate-pulse"></i> Rabbani Spirit Quest v2.0
                </div>
                <h1 class="text-3xl md:text-5xl font-extrabold font-game tracking-tight text-white leading-tight">
                    Set Your Spirit Target,<br> <span class="text-questSecondary">Level Up Your Soul!</span>
                </h1>
                <p class="text-teal-100 text-xs md:text-sm mt-3 max-w-xl leading-relaxed">
                    Hai Pejuang Rabbani! Ibadah harian adalah pengisi energi jiwamu agar senantiasa sehat, cerdas, dan dilingkupi petunjuk Allah. Yuk input capaian ibadahmu sepekan ini!
                </p>
            </div>
            
            <!-- Student Widget -->
            <div class="bg-questDark/70 backdrop-blur-md border border-white/10 rounded-2xl p-6 w-full md:w-80 shadow-2xl">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-12 h-12 rounded-full bg-questSecondary flex items-center justify-center text-questDark text-2xl font-bold flex-shrink-0">
                        <i class="fa-solid fa-user-ninja"></i>
                    </div>
                    <div class="flex-grow space-y-2">
                        <input type="text" id="player-name-input" oninput="updatePlayerName()" placeholder="Nama Siswa..." class="bg-white/10 border border-white/20 text-white font-bold rounded-lg px-2.5 py-1 text-sm focus:outline-none focus:border-questSecondary w-full placeholder-teal-200/50">
                        
                        <div class="grid grid-cols-2 gap-2">
                            <!-- Class Dropdown selection -->
                            <select id="player-class-select" onchange="updatePlayerClass()" class="bg-white/10 border border-white/20 text-white font-bold rounded-lg px-2 py-1 text-xs focus:outline-none focus:border-questSecondary w-full cursor-pointer">
                                <option value="" class="text-slate-800" disabled selected>Pilih Kelas</option>
                                <option value="VII - A" class="text-slate-800">VII - A</option>
                                <option value="VII - B" class="text-slate-800">VII - B</option>
                                <option value="VIII - A" class="text-slate-800">VIII - A</option>
                                <option value="VIII - B" class="text-slate-800">VIII - B</option>
                                <option value="IX - A" class="text-slate-800">IX - A</option>
                                <option value="IX - B" class="text-slate-800">IX - B</option>
                            </select>
                            
                            <!-- Week selection -->
                            <select id="recap-week-select" onchange="updateRecapWeek()" class="bg-white/10 border border-white/20 text-white font-bold rounded-lg px-2 py-1 text-xs focus:outline-none focus:border-questSecondary w-full cursor-pointer">
                                <option value="Pekan 1" class="text-slate-800" selected>Pekan 1</option>
                                <option value="Pekan 2" class="text-slate-800">Pekan 2</option>
                                <option value="Pekan 3" class="text-slate-800">Pekan 3</option>
                                <option value="Pekan 4" class="text-slate-800">Pekan 4</option>
                                <option value="Pekan 5" class="text-slate-800">Pekan 5</option>
                            </select>
                        </div>
                        
                        <!-- Date selection -->
                        <div class="relative">
                            <span class="absolute right-2 top-1 text-[8px] text-teal-200 uppercase font-semibold pointer-events-none">Tanggal Log</span>
                            <input type="date" id="recap-date-input" onchange="updateRecapDate()" class="bg-white/10 border border-white/20 text-white font-bold rounded-lg px-2.5 py-1 text-xs focus:outline-none focus:border-questSecondary w-full cursor-pointer">
                        </div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between text-xs font-semibold text-teal-100">
                        <span>SPIRIT BATTERY LEVEL</span>
                        <span id="spirit-level-text">WARRIOR (10%)</span>
                    </div>
                    <div class="h-3 bg-white/10 rounded-full overflow-hidden p-0.5 border border-white/5">
                        <div id="spirit-progress-bar" class="h-full bg-gradient-to-r from-gameRed via-yellow-400 to-gameGreen rounded-full transition-all duration-500" style="width: 10%;"></div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN INTERACTIVE HUB -->
    <main class="max-w-6xl mx-auto px-4 mt-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- LEFT COLUMN: SPIRITUAL COUNTERS & TRACKING (7 COLS) -->
        <section class="lg:col-span-7 flex flex-col gap-6">
            
            <!-- THE BATTERY INTERACTIVE BOX -->
            <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-6 md:p-8">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h2 class="text-xl md:text-2xl font-bold text-questPrimary font-game flex items-center gap-2">
                            <i class="fa-solid fa-battery-three-quarters text-questSecondary"></i> Charger Jiwa Pejuang
                        </h2>
                        <p class="text-xs text-slate-500 mt-1">Masukkan jumlah ibadah yang sudah kamu lakukan sepekan ini dengan menekan tombol angka yang sesuai.</p>
                    </div>
                    <button onclick="resetCounters()" class="text-xs bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold px-3 py-1.5 rounded-lg transition-all flex items-center gap-1">
                        <i class="fa-solid fa-rotate-left"></i> <span>Reset Semua</span>
                    </button>
                </div>
                
                <!-- Dynamic Soul Status Report -->
                <div class="bg-gradient-to-b from-slate-50 to-slate-100/50 border border-slate-200/60 rounded-2xl p-6 flex flex-col md:flex-row items-center gap-6 justify-between relative overflow-hidden mb-8">
                    <div class="flex items-center relative w-full max-w-[240px] md:w-48 h-28 bg-slate-200 rounded-2xl p-2 border-2 border-slate-300">
                        <div id="sim-battery-bar" class="h-full bg-gradient-to-r from-gameRed to-orange-500 rounded-xl transition-all duration-500 flex items-center justify-center font-bold text-white text-base drop-shadow-md" style="width: 10%;">
                            <span id="sim-pct">10%</span>
                        </div>
                        <div class="absolute right-[-10px] top-1/2 -translate-y-1/2 w-2.5 h-10 bg-slate-300 rounded-r-lg"></div>
                    </div>

                    <div class="flex-grow bg-white border border-slate-100 p-4 rounded-xl min-h-[120px] flex flex-col justify-between">
                        <div>
                            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">STATUS RUHIYAH:</span>
                            <h3 id="sim-status-title" class="font-bold text-gameRed text-lg font-game">Jiwa Remaja Low-Bat</h3>
                            <p id="sim-status-desc" class="text-xs text-slate-600 mt-1">Sering lelah belajar, gampang emosi, hampa, cemas berlebihan. Butuh segera dicolok ke charger iman!</p>
                        </div>
                        <div id="sim-status-buff" class="mt-3 p-2 rounded-lg bg-red-50 border border-red-100/50 text-[11px] text-gameRed font-semibold flex items-center gap-1.5">
                            <i class="fa-solid fa-bolt-lightning animate-bounce"></i> Tekan tombol ibadah di bawah untuk mengisi daya!
                        </div>
                    </div>
                </div>

                <!-- INPUT FORM: NUMERIC SELECTION BADGES -->
                <div class="space-y-6">
                    
                    <!-- 1. Dzikir Al-Ma'tsurat -->
                    <div class="border border-slate-100 bg-slate-50/50 rounded-2xl p-4">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xs font-extrabold text-questPrimary uppercase tracking-wider flex items-center gap-2">
                                <i class="fa-solid fa-shield text-questSecondary"></i> 1. Dzikir Al-Ma'tsurat
                            </span>
                            <span class="text-xs font-bold text-slate-500">Target: <strong class="text-questPrimary">7x / Pekan</strong></span>
                        </div>
                        <p class="text-[11px] text-slate-500 mb-3">Menenangkan hati dan perisai jiwa menghadapi aktivitas belajar harian.</p>
                        <div class="flex flex-wrap gap-1.5" id="btn-group-matsurat">
                            <!-- Populated Dynamically with 0-7 buttons -->
                        </div>
                    </div>

                    <!-- 2. Shalat Dhuha -->
                    <div class="border border-slate-100 bg-slate-50/50 rounded-2xl p-4">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xs font-extrabold text-questPrimary uppercase tracking-wider flex items-center gap-2">
                                <i class="fa-solid fa-sun text-questSecondary"></i> 2. Shalat Dhuha
                            </span>
                            <span class="text-xs font-bold text-slate-500">Target: <strong class="text-questPrimary">7x / Pekan</strong></span>
                        </div>
                        <p class="text-[11px] text-slate-500 mb-3">Membuka pintu berkah, melancarkan kecerdasan berpikir dan kelapangan rezeki.</p>
                        <div class="flex flex-wrap gap-1.5" id="btn-group-dhuha">
                            <!-- Populated Dynamically with 0-7 buttons -->
                        </div>
                    </div>

                    <!-- 3. Shalat Qobliyah & Ba'diyah -->
                    <div class="border border-slate-100 bg-slate-50/50 rounded-2xl p-4">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xs font-extrabold text-questPrimary uppercase tracking-wider flex items-center gap-2">
                                <i class="fa-solid fa-circle-plus text-questSecondary"></i> 3. Sunnah Rawatib (Qobliyah & Ba'diyah)
                            </span>
                            <span class="text-xs font-bold text-slate-500">Target: <strong class="text-questPrimary">21x / Pekan</strong></span>
                        </div>
                        <p class="text-[11px] text-slate-500 mb-3">Pelindung shalat wajibmu sekaligus jaminan istana megah di surga.</p>
                        <div class="flex flex-wrap gap-1 md:gap-1.5 max-h-24 overflow-y-auto p-1 border border-slate-200/50 rounded-xl" id="btn-group-rawatib">
                            <!-- Populated Dynamically with 0-21 buttons -->
                        </div>
                    </div>

                    <!-- 4. Shalat Fardhu Berjamaah -->
                    <div class="border border-slate-100 bg-slate-50/50 rounded-2xl p-4">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xs font-extrabold text-questPrimary uppercase tracking-wider flex items-center gap-2">
                                <i class="fa-solid fa-users text-questSecondary"></i> 4. Berjamaah di Masjid (5 Waktu)
                            </span>
                            <span class="text-xs font-bold text-slate-500">Target: <strong class="text-questPrimary">35x / Pekan</strong></span>
                        </div>
                        <p class="text-[11px] text-slate-500 mb-3">Pahala dilipatgandakan 27x lipat dan membangun kecerdasan sosial bersama rekan sebaya.</p>
                        <div class="flex flex-wrap gap-1 md:gap-1.5 max-h-32 overflow-y-auto p-1 border border-slate-200/50 rounded-xl" id="btn-group-jamaah">
                            <!-- Populated Dynamically with 0-35 buttons -->
                        </div>
                    </div>

                    <!-- 5. Puasa Sunnah Kamis -->
                    <div class="border border-slate-100 bg-slate-50/50 rounded-2xl p-4">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xs font-extrabold text-questPrimary uppercase tracking-wider flex items-center gap-2">
                                <i class="fa-solid fa-water text-questSecondary"></i> 5. Puasa Sunnah Kamis
                            </span>
                            <span class="text-xs font-bold text-slate-500">Target: <strong class="text-questPrimary">1x / Pekan</strong></span>
                        </div>
                        <p class="text-[11px] text-slate-500 mb-3">Detoks racun fisik dan mental, serta meningkatkan daya tahan kontrol emosi.</p>
                        <div class="flex flex-wrap gap-1.5" id="btn-group-puasa">
                            <!-- Populated Dynamically with 0-1 buttons -->
                        </div>
                    </div>

                    <!-- 6. Shalat Tahajjud -->
                    <div class="border border-slate-100 bg-slate-50/50 rounded-2xl p-4">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xs font-extrabold text-questPrimary uppercase tracking-wider flex items-center gap-2">
                                <i class="fa-solid fa-moon text-questSecondary"></i> 6. Shalat Tahajjud (Malam)
                            </span>
                            <span class="text-xs font-bold text-slate-500">Target: <strong class="text-questPrimary">2x / Pekan</strong></span>
                        </div>
                        <p class="text-[11px] text-slate-500 mb-3">Akses VIP sepertiga malam terakhir, waktu mustajab bermunajat dan meminta cita-cita luhur.</p>
                        <div class="flex flex-wrap gap-1.5" id="btn-group-tahajjud">
                            <!-- Populated Dynamically with 0-2 buttons -->
                        </div>
                    </div>

                </div>

            </div>

        </section>

        <!-- RIGHT COLUMN: UPGRADED RABBANI CONTRACT CARD & CLOUD SYNC (5 COLS) -->
        <section class="lg:col-span-5 flex flex-col gap-6">
            
            <!-- CONTROLS & DATABASE SYNC PANEL -->
            <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-6">
                <h3 class="font-bold text-questPrimary font-game text-base flex items-center gap-2 mb-2">
                    <i class="fa-solid fa-cloud-arrow-up text-questSecondary"></i> Cloud Simpan & Muat Capaian
                </h3>
                <p class="text-xs text-slate-500 mb-4">Simpan datamu agar Ustaz/Ustazah dapat merekap pencapaian ibadahmu secara real-time dari portal pendidik.</p>
                
                <div class="flex flex-col gap-2.5">
                    <button onclick="saveStudentProgress()" class="w-full bg-questPrimary hover:bg-questLight text-white py-3 px-4 rounded-xl font-bold text-sm tracking-wide transition-all flex items-center justify-center gap-2 shadow-md">
                        <i class="fa-solid fa-floppy-disk"></i> <span>KIRIM CAPAIAN KE DATABASE</span>
                    </button>
                    
                    <div id="sync-status" class="hidden text-xs py-2 px-3 rounded-lg text-center font-semibold">
                        <!-- Filled on response -->
                    </div>
                </div>
            </div>

            <!-- UPGRADED CUSTOMIZABLE CONTRACT CARD -->
            <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-6 flex-grow">
                <div class="mb-4">
                    <span class="text-xs font-extrabold text-questSecondary uppercase tracking-widest">PREVIEW KARTU:</span>
                    <h2 class="text-lg md:text-xl font-bold text-questPrimary font-game mt-1 flex items-center gap-2">
                        <i class="fa-solid fa-id-card-clip text-questSecondary"></i> Rabbani Contract Card
                    </h2>
                    <p class="text-xs text-slate-500">Sesuaikan profil spiritualmu! Kartu ini akan terupdate otomatis dan bisa diprint untuk ditunjukkan ke Ustaz/Ustazah.</p>
                </div>

                <!-- Custom Card Rendering Area -->
                <div class="border-2 border-dashed border-questSecondary/40 rounded-2xl p-5 bg-gradient-to-br from-questPrimary via-questDark to-slate-900 text-white relative overflow-hidden shadow-xl" id="contract-card-element">
                    
                    <!-- Glow graphics -->
                    <div class="absolute right-[-30px] bottom-[-30px] opacity-10 text-9xl">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    
                    <!-- Decorative background ring -->
                    <div class="absolute -top-12 -left-12 w-32 h-32 bg-questSecondary/10 rounded-full blur-xl"></div>

                    <div class="flex justify-between items-start pb-3 border-b border-white/10 relative z-10">
                        <div>
                            <h4 class="font-extrabold text-xs tracking-wider font-game text-questSecondary uppercase">KONTRAK SANG PEJUANG</h4>
                            <p class="text-[9px] text-teal-200 tracking-widest font-semibold uppercase">SMP IT BINA INSANI KEDIRI</p>
                        </div>
                        <span class="bg-questSecondary/20 border border-questSecondary/30 text-questSecondary px-2 py-0.5 rounded text-[9px] font-bold tracking-wider" id="player-badge">PEJUANG</span>
                    </div>

                    <!-- Card Body -->
                    <div class="my-4 space-y-4 relative z-10 text-xs">
                        <div class="flex items-center gap-3">
                            <!-- Avatar Selector Inside Card -->
                            <div class="relative group cursor-pointer" onclick="cycleAvatar()">
                                <div class="w-12 h-12 rounded-full bg-questSecondary/20 border-2 border-questSecondary flex items-center justify-center text-xl text-questSecondary" id="card-avatar-container">
                                    <i class="fa-solid fa-user-ninja" id="card-avatar"></i>
                                </div>
                                <div class="absolute bottom-0 right-0 w-4 h-4 bg-white text-questDark rounded-full flex items-center justify-center text-[8px] border border-questDark shadow font-bold">
                                    <i class="fa-solid fa-rotate"></i>
                                </div>
                            </div>
                            
                            <div>
                                <span class="text-[8px] text-teal-200 block uppercase tracking-wider font-medium">NAMA SANG PEJUANG:</span>
                                <div class="flex flex-wrap items-baseline gap-2">
                                    <span id="card-player-name" class="font-extrabold text-sm text-white">Guest Warrior</span>
                                    <span id="card-player-class" class="text-[10px] font-bold text-questSecondary">VII - A</span>
                                </div>
                                <span class="text-[9px] text-teal-100 block italic cursor-pointer underline hover:text-white" onclick="changeCustomRole()" id="card-custom-role">Role: Pejuang Subuh (Ganti)</span>
                            </div>
                        </div>

                        <!-- Target Recap Section -->
                        <div>
                            <span class="text-[8px] text-teal-200 block uppercase tracking-wider font-medium">REKAP CAPAIAN MINGGU INI:</span>
                            <div class="grid grid-cols-2 gap-x-2 gap-y-1 text-[10px] mt-1.5 text-slate-100">
                                <div><i class="fa-solid fa-shield text-questSecondary mr-1"></i> Dzikir: <span class="font-bold text-white" id="recap-matsurat">0/7</span></div>
                                <div><i class="fa-solid fa-sun text-questSecondary mr-1"></i> Dhuha: <span class="font-bold text-white" id="recap-dhuha">0/7</span></div>
                                <div><i class="fa-solid fa-circle-plus text-questSecondary mr-1"></i> Rawatib: <span class="font-bold text-white" id="recap-rawatib">0/21</span></div>
                                <div><i class="fa-solid fa-users text-questSecondary mr-1"></i> Jamaah: <span class="font-bold text-white" id="recap-jamaah">0/35</span></div>
                                <div><i class="fa-solid fa-water text-questSecondary mr-1"></i> Puasa: <span class="font-bold text-white" id="recap-puasa">0/1</span></div>
                                <div><i class="fa-solid fa-moon text-questSecondary mr-1"></i> Tahajjud: <span class="font-bold text-white" id="recap-tahajjud">0/2</span></div>
                            </div>
                        </div>

                        <!-- Editable Personal Commitment -->
                        <div>
                            <span class="text-[8px] text-teal-200 block uppercase tracking-wider font-medium flex justify-between items-center">
                                <span>TEKAD DARI DALAM HATI (KLIK UNTUK EDIT):</span>
                            </span>
                            <textarea id="card-commitment-text" oninput="saveLocalCommitment()" class="w-full bg-black/20 border border-white/10 rounded-lg p-2 text-[10px] italic text-teal-100 focus:outline-none focus:border-questSecondary h-14 resize-none leading-relaxed mt-1" placeholder="Tuliskan alasan terdalam kenapa kamu butuh ibadah di sini..."></textarea>
                        </div>

                        <!-- REALTIME USTADZ FEEDBACK BOX -->
                        <div id="ustadz-feedback-wrapper" class="hidden border border-yellow-500/40 bg-yellow-500/10 rounded-xl p-3 shadow-inner">
                            <span class="text-[8px] text-questSecondary font-extrabold tracking-widest uppercase flex items-center gap-1">
                                <i class="fa-solid fa-comments"></i> CATATAN DARI USTAZ/USTAZAH:
                            </span>
                            <p id="ustadz-feedback-text" class="text-[10.5px] font-semibold text-slate-100 italic mt-1 leading-relaxed">
                                "Selesaikan targetmu pekan ini nak, bapak pantau terus!"
                            </p>
                        </div>

                    </div>

                    <div class="flex justify-between items-center pt-3 border-t border-white/10 text-[8px] text-teal-200">
                        <div>
